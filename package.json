{
  "name": "side-docs",
  "displayName": "Side Docs",
  "version": "1.1.1",
  "description": "Show a configured Markdown document in a dedicated tab.",
  "publisher": "szymonb",
  "author": "szymonb",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/szymboro/side-docs.git"
  },
  "homepage": "https://github.com/szymboro/side-docs#readme",
  "bugs": {
    "url": "https://github.com/szymboro/side-docs/issues"
  },
  "icon": "media/docs.png",
  "categories": [
    "Other"
  ],
  "keywords": [
    "docs",
    "documentation",
    "markdown",
    "sidebar",
    "preview",
    "wiki",
    "knowledge-base"
  ],
  "engines": {
    "vscode": "^1.105.0"
  },
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "docsPanel.refresh",
        "title": "Refresh Docs",
        "icon": "$(refresh)",
        "shortTitle": "Refresh Docs",
        "category": "Side Docs"
      },
      {
        "command": "docsPanel.searchDocs",
        "title": "Search Docs",
        "icon": "$(search)",
        "shortTitle": "Search Docs",
        "category": "Side Docs"
      },
      {
        "command": "docsPanel.openRendered",
        "title": "Open Rendered Docs",
        "icon": "$(open-preview)",
        "category": "Side Docs"
      },
      {
        "command": "docsPanel.searchInPreview",
        "title": "Search In Preview",
        "icon": "$(search)",
        "category": "Side Docs"
      },
      {
        "command": "docsPanel.previewBack",
        "title": "Preview Back",
        "icon": "$(arrow-left)",
        "category": "Side Docs"
      },
      {
        "command": "docsPanel.previewForward",
        "title": "Preview Forward",
        "icon": "$(arrow-right)",
        "category": "Side Docs"
      }
    ],
    "keybindings": [
      {
        "command": "docsPanel.searchInPreview",
        "key": "ctrl+f",
        "mac": "cmd+f",
        "when": "webviewFocus && activeWebviewPanelId == 'docsPanel.preview'"
      },
      {
        "command": "docsPanel.previewBack",
        "key": "alt+left",
        "when": "webviewFocus && activeWebviewPanelId == 'docsPanel.preview'"
      },
      {
        "command": "docsPanel.previewForward",
        "key": "alt+right",
        "when": "webviewFocus && activeWebviewPanelId == 'docsPanel.preview'"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "docsPanelContainer",
          "title": "Side Docs",
          "icon": "media/docs.png"
        }
      ]
    },
    "views": {
      "docsPanelContainer": [
        {
          "id": "docsPanel.toc",
          "name": "Side Docs",
          "icon": "media/docs.png"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "docsPanel.refresh",
          "icon": "$(refresh)",
          "when": "view == docsPanel.toc",
          "group": "navigation"
        },
        {
          "command": "docsPanel.searchDocs",
          "icon": "$(search)",
          "when": "view == docsPanel.toc",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "Side Docs",
      "properties": {
        "docsPanel.paths": {
          "type": "array",
          "default": [
            "docs"
          ],
          "items": {
            "type": "string"
          },
          "description": "Project documentation paths to show in the Docs sidebar. Each entry can point to a Markdown file or directory and may be absolute or workspace-relative."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "dependencies": {
    "markdown-it": "14.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/markdown-it": "^14.1.2",
    "@types/vscode": "^1.105.0",
    "typescript": "6.0.2"
  }
}
